{
  "name": "@alchemist/web-app",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "node ./scripts/dev-server.mjs",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && node ./scripts/dev-server.mjs",
    "build": "pnpm run clean && NODE_ENV=production NODE_OPTIONS=--max-old-space-size=8192 next build",
    "build:fresh": "pnpm run build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@alchemist/shared-engine": "workspace:*",
    "@alchemist/shared-types": "workspace:*",
    "@alchemist/shared-ui": "workspace:*",
    "@msgpack/msgpack": "^3.1.3",
    "@react-three/drei": "9",
    "@react-three/fiber": "8",
    "fzstd": "^0.1.1",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
