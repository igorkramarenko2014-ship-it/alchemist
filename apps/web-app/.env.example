# Copy to `.env.local` in THIS folder (apps/web-app). Never commit real keys.
#
# GROQ_API_KEY=        → Groq (Llama / Hermes triad route)
# DEEPSEEK_API_KEY=    → DeepSeek (Athena)
# QWEN_API_KEY=        → DashScope or OpenRouter (Hestia) — use OpenRouter-shaped key with OpenRouter base
# QWEN_BASE_URL=       → default DashScope compatible v1; e.g. https://openrouter.ai/api/v1
# LLAMA_API_KEY=       → optional alias for Groq if you skip GROQ_API_KEY
# LLAMA_GROQ_MODEL=    → optional, e.g. llama-3.3-70b-versatile

GROQ_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
# QWEN_BASE_URL=https://openrouter.ai/api/v1
LLAMA_API_KEY=
# LLAMA_GROQ_MODEL=
