{
  "name": "alchemist",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/with-pnpm.mjs --filter @alchemist/web-app dev",
    "dev:3000": "node scripts/dev-alchemist-port.mjs 3000",
    "fresh:3000": "node scripts/dev-alchemist-port.mjs 3000 --fresh",
    "dev:turbo": "node scripts/with-pnpm.mjs exec turbo run dev --filter=@alchemist/web-app",
    "dev:web": "node scripts/with-pnpm.mjs --filter @alchemist/web-app dev",
    "dev:all": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=@alchemist/mobile-app",
    "go": "node scripts/with-pnpm.mjs install && node scripts/with-pnpm.mjs --filter @alchemist/web-app dev",
    "go:fresh": "node scripts/with-pnpm.mjs install && node scripts/with-pnpm.mjs run web:dev:fresh",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docs:list": "bash scripts/list-project-docs.sh",
    "clean": "rm -rf apps/web-app/.next apps/mobile-app/.expo .turbo && node scripts/with-pnpm.mjs exec turbo daemon stop 2>/dev/null || true",
    "web:rebuild": "node scripts/with-pnpm.mjs run clean && node scripts/with-pnpm.mjs exec turbo run build --filter=@alchemist/web-app --force",
    "web:next-force": "rm -rf apps/web-app/.next .turbo && node scripts/with-pnpm.mjs exec turbo run build --filter=@alchemist/web-app --force",
    "web:next-build": "pnpm --filter @alchemist/web-app run build",
    "web:dev:fresh": "node scripts/with-pnpm.mjs run clean && node scripts/with-pnpm.mjs --filter @alchemist/web-app dev",
    "fresh": "node scripts/with-pnpm.mjs run web:dev:fresh",
    "app:repair": "node scripts/with-pnpm.mjs run web:dev:fresh",
    "fix": "node scripts/with-pnpm.mjs run app:repair",
    "ix": "node scripts/with-pnpm.mjs run app:repair",
    "dev:recover": "node scripts/recover-web-dev.mjs && node scripts/with-pnpm.mjs --filter @alchemist/web-app dev",
    "test:engine": "pnpm --filter @alchemist/shared-engine test && pnpm --filter @alchemist/serum2-encoder test",
    "test:engine:grep": "pnpm --filter @alchemist/shared-engine exec vitest run",
    "verify:harsh": "node scripts/run-verify-with-summary.mjs verify-harsh",
    "verify:harsh:selective": "ALCHEMIST_SELECTIVE_VERIFY=1 node scripts/run-verify-with-summary.mjs verify-harsh",
    "verify:web": "node scripts/run-verify-with-summary.mjs verify-web",
    "harshcheck": "node scripts/harshcheck.mjs",
    "harshchek": "node scripts/harshcheck.mjs",
    "test:gate": "node scripts/test-gate-hint.mjs",
    "validate:offsets": "node scripts/validate-offsets-if-sample.mjs",
    "assert:hard-gate": "node scripts/assert-hard-gate.mjs",
    "check:transparent": "node scripts/check-no-shadow-patterns.mjs",
    "alc:doctor": "node scripts/doctor.mjs",
    "env:check": "node scripts/check-env-local.mjs",
    "check:ready": "pnpm env:check && pnpm verify:harsh",
    "verify:keys": "node scripts/verify-provider-keys.mjs",
    "perf:boss": "pnpm --filter @alchemist/shared-engine perf:boss",
    "git:save": "node scripts/git-save.mjs",
    "save": "node scripts/git-save.mjs",
    "git:agent": "node scripts/git-agent-flow.mjs",
    "cmt": "node scripts/git-commit-only.mjs",
    "psh": "node scripts/git-push-only.mjs",
    "fire:sync": "node scripts/sync-fire-md.mjs",
    "brain:sync": "node scripts/sync-brain-fusion.mjs",
    "igor:sync": "node scripts/sync-igor-orchestrator.mjs",
    "igor:heal": "node scripts/igor-self-heal.mjs",
    "igor:apply": "node scripts/igor-apply-proposal.mjs",
    "github:first-push": "node scripts/github-first-push.mjs",
    "test:real-gates": "tsx scripts/calibrate-gates.ts",
    "build:wasm": "pnpm --filter @alchemist/fxp-encoder build:wasm",
    "analyze:serum2": "node scripts/analyze-serum2-format.mjs",
    "talent:sync-whatmodels": "node scripts/sync-whatmodels-vendor.mjs"
  },
  "devDependencies": {
    "@alchemist/shared-engine": "workspace:*",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
