{
  "name": "alchemist",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "build": "turbo run build",
    "dev": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3000",
    "dev:plain": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3000",
    "dev:guardian": "node scripts/happy-panda.mjs && node scripts/dev-guardian.mjs 3000",
    "dev:guardian:fresh": "node scripts/happy-panda.mjs && node scripts/dev-guardian.mjs 3000 --fresh",
    "dev:3000": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3000",
    "fresh:3000": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3000 --fresh",
    "dev:3010": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3010",
    "fresh:3010": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3010 --fresh",
    "dev:turbo": "node scripts/happy-panda.mjs && node scripts/with-pnpm.mjs exec turbo run dev --filter=@alchemist/web-app",
    "dev:web": "node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3000",
    "dev:all": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=@alchemist/mobile-app",
    "go": "node scripts/with-pnpm.mjs install && node scripts/happy-panda.mjs && node scripts/dev-alchemist-port.mjs 3000",
    "go:fresh": "node scripts/with-pnpm.mjs install && node scripts/with-pnpm.mjs run web:dev:fresh",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docs:list": "bash scripts/list-project-docs.sh",
    "clean": "rm -rf apps/web-app/.next apps/mobile-app/.expo .turbo && node scripts/with-pnpm.mjs exec turbo daemon stop 2>/dev/null || true",
    "web:rebuild": "node scripts/with-pnpm.mjs run clean && node scripts/with-pnpm.mjs exec turbo run build --filter=@alchemist/web-app --force",
    "web:next-force": "rm -rf apps/web-app/.next .turbo && node scripts/with-pnpm.mjs exec turbo run build --filter=@alchemist/web-app --force",
    "web:next-build": "pnpm --filter @alchemist/web-app run build",
    "web:dev:fresh": "node scripts/happy-panda.mjs && node scripts/with-pnpm.mjs run clean && node scripts/dev-alchemist-port.mjs 3000",
    "fresh": "node scripts/with-pnpm.mjs run web:dev:fresh",
    "app:repair": "node scripts/with-pnpm.mjs run web:dev:fresh",
    "fix": "node scripts/with-pnpm.mjs run app:repair",
    "ix": "node scripts/with-pnpm.mjs run app:repair",
    "dev:recover": "node scripts/happy-panda.mjs && node scripts/recover-web-dev.mjs && node scripts/dev-alchemist-port.mjs 3000",
    "test:engine": "pnpm --filter @alchemist/shared-engine test && pnpm --filter @alchemist/serum2-encoder test",
    "test:triad-parity": "pnpm --filter @alchemist/shared-engine exec vitest run tests/triad-parity-harness.test.ts",
    "pnh:ghost": "pnpm --filter @alchemist/shared-engine exec vitest run tests/pnh-ghost-run.test.ts",
    "pnh:model-warfare": "tsx scripts/pnh-model-warfare.ts",
    "pnh:simulate": "tsx scripts/pnh-simulate.ts --",
    "pnh:proposals": "tsx scripts/pnh-proposals.ts",
    "pnh:wargame": "tsx scripts/pnh-wargame.ts",
    "test:engine:grep": "pnpm --filter @alchemist/shared-engine exec vitest run",
    "verify:harsh": "pnpm identity:sync && pnpm igor:sync && node scripts/run-verify-with-summary.mjs verify-harsh && node scripts/aggregate-truth.mjs && node scripts/validate-truth-matrix.mjs && node scripts/validate-fire-metrics.mjs && node scripts/validate-learning-corpus.mjs && pnpm personas:verify",
    "verify:harsh:fire": "ALCHEMIST_FIRE_SYNC=1 node scripts/run-verify-with-summary.mjs verify-harsh",
    "verify:harsh:selective": "ALCHEMIST_SELECTIVE_VERIFY=1 node scripts/run-verify-with-summary.mjs verify-harsh",
    "verify:web": "node scripts/run-verify-with-summary.mjs verify-web",
    "verify:ci": "pnpm assert:hard-gate && node scripts/assert-encoder-diff-prerequisites.mjs && pnpm verify:harsh && node scripts/assert-fire-sync-clean.mjs && pnpm check:truth && node scripts/enforce-release-strict-gates.mjs",
    "predeploy": "node scripts/predeploy-wasm.mjs && node scripts/release-audit-receipt.mjs && node scripts/demo-status.mjs",
    "predeploy:vst": "node scripts/predeploy-vst.mjs",
    "harshcheck": "pnpm identity:sync && pnpm igor:sync && node scripts/harshcheck.mjs",
    "harshcheck:wasm": "node scripts/verify-with-wasm.mjs",
    "verify:harsh:wasm": "ALCHEMIST_VERIFY_WASM_CHAIN=fast node scripts/verify-with-wasm.mjs",
    "harshcheck:fire": "ALCHEMIST_FIRE_SYNC=1 node scripts/harshcheck.mjs",
    "harshchek": "node scripts/harshcheck.mjs",
    "test:gate": "node scripts/test-gate-hint.mjs",
    "validate:offsets": "node scripts/validate-offsets-if-sample.mjs",
    "vst:observe": "tsx scripts/vst-bridge-cli.ts",
    "vst:observe:gate": "node scripts/vst-observer-hook.mjs",
    "assert:vst": "node scripts/assert-vst-available.mjs",
    "verify:vst": "node scripts/assert-vst-available.mjs && node scripts/with-pnpm.mjs vst:observe:gate",
    "build:vst:full": "node scripts/vst-build.mjs",
    "assert:hard-gate": "node scripts/assert-hard-gate.mjs",
    "assert:wasm": "node scripts/assert-wasm-available.mjs",
    "check:transparent": "node scripts/check-no-shadow-patterns.mjs",
    "alc:doctor": "node scripts/doctor.mjs",
    "panda": "node scripts/happy-panda.mjs",
    "env:check": "node scripts/check-env-local.mjs",
    "check:ready": "pnpm env:check && pnpm verify:harsh",
    "verify:keys": "node scripts/verify-provider-keys.mjs",
    "perf:boss": "pnpm --filter @alchemist/shared-engine perf:boss",
    "git:save": "node scripts/git-save.mjs",
    "save": "node scripts/git-save.mjs",
    "git:agent": "node scripts/git-agent-flow.mjs",
    "cmt": "node scripts/git-commit-only.mjs",
    "psh": "node scripts/git-push-only.mjs",
    "fire:sync": "node scripts/sync-initiator-skills.mjs && node scripts/sync-fire-md.mjs && node scripts/aggregate-truth.mjs && node scripts/sync-external-brief.mjs && node scripts/validate-truth-matrix.mjs && node scripts/validate-fire-metrics.mjs",
    "initiator:sync": "node scripts/sync-initiator-skills.mjs",
    "brain:sync": "node scripts/sync-brain-fusion.mjs",
    "igor:sync": "node scripts/sync-igor-orchestrator.mjs",
    "igor:heal": "node scripts/igor-self-heal.mjs",
    "igor:apply": "node scripts/igor-apply-proposal.mjs",
    "igor:skill-promote": "node scripts/igor-skill-promote.mjs",
    "igor:docs": "node scripts/igor-docs.mjs",
    "igor:ci": "node scripts/igor-ci-check.mjs",
    "igor:checkup": "tsx scripts/igor-checkup.ts",
    "iom:snapshot": "tsx scripts/iom-snapshot.ts",
    "iom:diff": "node scripts/iom-diff.mjs",
    "iom:status": "node scripts/iom-status.mjs",
    "iom:policy-check": "node scripts/iom-policy-check.mjs",
    "github:first-push": "node scripts/github-first-push.mjs",
    "test:real-gates": "tsx scripts/calibrate-gates.ts",
    "test:truth-matrix": "pnpm --filter @alchemist/web-app exec vitest run __tests__/truth-matrix.test.ts",
    "learning:forget-presets": "node scripts/learning-forget-presets.mjs",
    "learning:teach": "node scripts/learning-teach-forget.mjs",
    "learning:rl": "node scripts/learning-teach-forget.mjs",
    "learning:sanitize": "pnpm learning:forget-presets && pnpm learning:verify",
    "learning:verify": "node scripts/validate-learning-corpus.mjs",
    "taste:validate": "node packages/shared-engine/learning/taste/scripts/validate-taste-index.mjs",
    "taste:build-index": "node packages/shared-engine/learning/taste/scripts/build-taste-index.mjs",
    "taste:rebuild": "node packages/shared-engine/learning/taste/scripts/build-taste-index.mjs && pnpm taste:validate",
    "learning:build-index": "node packages/shared-engine/learning/scripts/build-learning-index.mjs",
    "learning:aggregate-telemetry": "node packages/shared-engine/learning/scripts/aggregate-learning-telemetry.mjs",
    "learning:forget-telemetry": "node scripts/learning-forget-telemetry.mjs",
    "learning:assess-fitness": "node scripts/learning-assess-fitness.mjs && node packages/shared-engine/learning/scripts/aggregate-learning-telemetry.mjs",
    "refinery:check": "tsx packages/shared-engine/transmutation/refinery/refinery-cli.mjs check",
    "refinery:apply": "tsx packages/shared-engine/transmutation/refinery/refinery-cli.mjs apply",
    "refinery:rollback": "tsx packages/shared-engine/transmutation/refinery/refinery-cli.mjs rollback",
    "preset:quality": "node --import tsx scripts/preset-quality-report.ts",
    "learning:enrich-preview": "tsx scripts/learning-enrich-preview.ts",
    "truth:aggregate": "node scripts/aggregate-truth.mjs",
    "truth:build": "pnpm verify:harsh && pnpm fire:sync",
    "truth:matrix": "node scripts/generate-truth-matrix.mjs",
    "identity:sync": "node scripts/aggregate-truth.mjs && node scripts/identity-sync.mjs",
    "check:truth": "node scripts/check-truth-parity.mjs",
    "check:parity": "node scripts/check-parity.mjs",
    "health:audit": "node scripts/health-release-audit.mjs",
    "release:audit": "node scripts/release-audit-receipt.mjs",
    "demo:status": "node scripts/demo-status.mjs",
    "demo:launch": "node scripts/demo-launch.mjs",
    "aiom:status": "node scripts/aiom-one-screen-status.mjs",
    "aiom:habit": "pnpm harshcheck && pnpm aiom:status",
    "presentation:build": "node scripts/presentation-automation.mjs",
    "presentation:keynote": "node scripts/presentation-automation.mjs --apply-keynote",
    "final:audit": "node scripts/final-audit.mjs",
    "receipt:godzilla": "node scripts/generate-godzilla-receipt.mjs",
    "triad:parity-diff": "pnpm exec tsx scripts/triad-parity-diff.ts",
    "build:wasm": "pnpm --filter @alchemist/fxp-encoder build:wasm",
    "vst:daemon": "pnpm --filter @alchemist/fxp-encoder run vst:daemon",
    "build:watcher": "pnpm --filter @alchemist/fxp-encoder run build:watcher",
    "build:vst": "node scripts/vst-build.mjs",
    "fxp:inspect": "node scripts/fxp-inspect.mjs",
    "analyze:serum2": "node scripts/analyze-serum2-format.mjs",
    "serum2:discover-mod-matrix": "pnpm --filter @alchemist/serum2-encoder run discover-mod-matrix",
    "talent:sync-whatmodels": "node scripts/sync-whatmodels-vendor.mjs",
    "estimate": "tsx scripts/engine-estimate.ts",
    "engine:estimate": "tsx scripts/engine-estimate.ts",
    "soe:migrate": "tsx scripts/migrate-structured-soe-hints.ts",
    "iom:ghost:check": "node scripts/iom-ghost-check.mjs",
    "personas:verify": "node packages/shared-engine/personas/scripts/validate-personas.mjs",
    "test:personas": "pnpm --filter @alchemist/shared-engine exec vitest run tests/personas-behavior.test.ts"
  },
  "devDependencies": {
    "@alchemist/fxp-encoder": "workspace:*",
    "@alchemist/shared-engine": "workspace:*",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
