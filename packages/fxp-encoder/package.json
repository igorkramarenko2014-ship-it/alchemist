{
  "name": "@alchemist/fxp-encoder",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./serum-offset-map.ts",
  "types": "./serum-offset-map.ts",
  "exports": {
    ".": "./serum-offset-map.ts",
    "./serum-offset-map": "./serum-offset-map.ts",
    "./wasm": {
      "types": "./pkg/fxp_encoder.d.ts",
      "import": "./pkg/fxp_encoder.js",
      "default": "./pkg/fxp_encoder.js"
    },
    "./wasm/init": {
      "types": "./pkg/fxp_encoder.d.ts",
      "import": "./pkg/fxp_encoder.js",
      "default": "./pkg/fxp_encoder.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:wasm": "npx --yes wasm-pack build --target web --out-dir pkg && node scripts/clear-stub-marker.cjs",
    "build": "node scripts/skip-if-no-rust.cjs",
    "sync-maps": "node scripts/sync-maps.cjs"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
