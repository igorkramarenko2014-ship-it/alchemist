{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.ts",
    "*.d.ts",
    "learning/**/*.ts",
    "talent/**/*.ts",
    "taxonomy/**/*.ts",
    "arbitration/**/*.ts",
    "perf/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
