{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemist.local/schemas/engine-lesson.schema.v1.json",
  "title": "EngineLesson",
  "description": "Single annotated learning unit for shared-engine corpus (Engine School). Schema contract v1.x.",
  "x-alchemist-schema-version": "1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "presetName",
    "style",
    "mappings",
    "character",
    "causalReasoning"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Must match x-alchemist-schema-version in lesson.schema.json; bump both when evolving the contract."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique lesson identifier, e.g. serum-lesson-000-stub"
    },
    "presetName": {
      "type": "string",
      "minLength": 2,
      "description": "Human-readable preset name used when teaching name→mapping→character"
    },
    "style": {
      "type": "string",
      "minLength": 1,
      "description": "Style category (taxonomy or DL staging label — not committed as binaries)"
    },
    "mappings": {
      "type": "object",
      "minProperties": 1,
      "description": "Abstract parameter emphasis (≥1 key); not raw .fxp offsets",
      "additionalProperties": true
    },
    "character": {
      "type": "string",
      "minLength": 20,
      "description": "Sonic character summary (non-trivial length)"
    },
    "causalReasoning": {
      "type": "string",
      "minLength": 40,
      "description": "Explicit causal chain (non-trivial length)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional sonic descriptors"
    }
  }
}
