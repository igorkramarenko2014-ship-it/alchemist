{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemist.local/schemas/engine-lesson.schema.v1.2.json",
  "title": "EngineLesson",
  "description": "Single annotated learning unit for shared-engine corpus (Engine School). v1.2 adds optional cluster id for archetype grouping.",
  "x-alchemist-schema-version": "1.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "presetName",
    "style",
    "mappings",
    "character",
    "causalReasoning",
    "priorityMappingKeys",
    "coreRules",
    "contrastWith"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["1.1", "1.2"],
      "description": "Lesson file revision; 1.2 adds optional cluster."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique lesson identifier, e.g. engine_school_role_model_v1 or engine_school_lesson_002"
    },
    "presetName": {
      "type": "string",
      "minLength": 2,
      "description": "Human-readable preset name used when teaching name→mapping→character"
    },
    "style": {
      "type": "string",
      "minLength": 1,
      "description": "Style category (taxonomy or DL staging label — not committed as binaries)"
    },
    "cluster": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Stable archetype bucket (e.g. bass_transient_punch) — cluster-first selection; advisory only"
    },
    "mappings": {
      "type": "object",
      "minProperties": 1,
      "description": "Abstract parameter emphasis (≥1 key); not raw .fxp offsets",
      "additionalProperties": true
    },
    "character": {
      "type": "string",
      "minLength": 20,
      "description": "Sonic character summary (non-trivial length)"
    },
    "causalReasoning": {
      "type": "string",
      "minLength": 40,
      "description": "Explicit causal chain (non-trivial length)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional sonic descriptors"
    },
    "priorityMappingKeys": {
      "type": "array",
      "description": "Top 2–3 mapping keys that most define this archetype (must be keys of mappings when present)",
      "minItems": 1,
      "maxItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "coreRules": {
      "type": "array",
      "description": "2–3 minimal irreducible causal rules (compression layer)",
      "minItems": 2,
      "maxItems": 3,
      "items": { "type": "string", "minLength": 12 }
    },
    "contrastWith": {
      "type": "object",
      "description": "Explicit contrast to another committed lesson (recommended)",
      "additionalProperties": false,
      "required": ["lessonId", "difference"],
      "properties": {
        "lessonId": {
          "type": "string",
          "minLength": 1,
          "description": "id of another lesson in corpus"
        },
        "difference": {
          "type": "string",
          "minLength": 40,
          "description": "Why this archetype differs (decision-grade, not a second full essay)"
        }
      }
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Optional pedagogical tier for selection / sequencing (advisory only)"
    },
    "lessonVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic revision counter for this lesson id (human-facing evolution tracking)"
    },
    "changelog": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Human-readable revision notes (newest first recommended)"
    },
    "replaces": {
      "type": "string",
      "minLength": 1,
      "description": "Optional prior lesson id superseded by this file (audit trail only)"
    },
    "antiPatterns": {
      "type": "array",
      "description": "What to avoid — teaches failure modes without overriding gates",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description"],
        "properties": {
          "description": { "type": "string", "minLength": 12 },
          "relatedTo": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "Mapping keys this anti-pattern touches (must be keys of mappings)"
          },
          "whyItFails": {
            "type": "string",
            "minLength": 8,
            "description": "Perceptual or mix consequence (advisory)"
          }
        }
      }
    },
    "heuristics": {
      "type": "array",
      "description": "Advisory bias hints — never gate overrides",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["condition", "bias"],
        "properties": {
          "condition": { "type": "string", "minLength": 4 },
          "bias": { "type": "string", "minLength": 4 },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "contrastMatrix": {
      "type": "object",
      "description": "Optional structured multi-axis contrast (supplements contrastWith)",
      "additionalProperties": false,
      "required": ["vs", "axes", "differences"],
      "properties": {
        "vs": {
          "type": "string",
          "minLength": 1,
          "description": "Other lesson id"
        },
        "axes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "differences": {
          "type": "object",
          "description": "Free-form axis → short contrast note",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
