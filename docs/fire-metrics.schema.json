{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemist.local/docs/fire-metrics.schema.json",
  "title": "Alchemist FIRE metrics snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "syncedDateUtc",
    "generatedAtUtc",
    "vitestTestsPassed",
    "vitestTestFilesPassed",
    "vitestTestTsOnDisk",
    "nextJsVersion",
    "vst3BundlePresent",
    "vst3BundleBasename",
    "vst3MainBinarySha256",
    "mon",
    "initiatorSkillsSha256",
    "learningOutcomes",
    "verification",
    "divergences"
  ],
  "properties": {
    "schemaVersion": { "const": 3 },
    "syncedDateUtc": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "vitestTestsPassed": { "type": "number" },
    "vitestTestFilesPassed": { "type": "number" },
    "vitestTestTsOnDisk": { "type": "number" },
    "nextJsVersion": { "type": "string", "minLength": 1 },
    "vst3BundlePresent": { "type": "boolean" },
    "vst3BundleBasename": { "type": ["string", "null"] },
    "vst3MainBinarySha256": { "type": ["string", "null"] },
    "mon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "ready", "source"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "ready": { "type": "boolean" },
        "source": { "type": "string", "minLength": 1 },
        "rawStatus": { "type": "string" }
      }
    },
    "initiatorSkillsSha256": { "type": ["string", "null"] },
    "learningOutcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateSuccessRate",
        "meanBestScoreWithLessons",
        "orderChangeRate",
        "tasteClusterHitRate",
        "authoritative",
        "note"
      ],
      "properties": {
        "candidateSuccessRate": { "type": "number" },
        "meanBestScoreWithLessons": { "type": "number" },
        "orderChangeRate": { "type": "number" },
        "tasteClusterHitRate": { "type": "number" },
        "authoritative": { "const": false },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "verification": { "type": "string", "minLength": 1 },
    "divergences": { "type": "array" }
  }
}
