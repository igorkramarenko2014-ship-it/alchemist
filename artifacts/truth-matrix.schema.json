{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemist.local/schemas/truth-matrix.schema.json",
  "title": "AIOM Truth Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "divergenceCheckedAtUtc",
    "verification",
    "sources",
    "metrics",
    "divergences",
    "trustless"
  ],
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 6
    },
    "integrityStatus": {
      "type": "string",
      "enum": ["nominal", "compromised", "degraded", "unverified"]
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "divergenceCheckedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "generationSequence": {
      "type": "number"
    },
    "generationNonce": {
      "type": "string"
    },
    "buildTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "traceRootHash": {
      "type": "string"
    },
    "signingKeyId": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "verification": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifyPostSummary",
        "metrics",
        "learningFitnessReport"
      ],
      "properties": {
        "verifyPostSummary": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "string",
          "minLength": 1
        },
        "learningFitnessReport": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testsPassed",
        "testsTotal",
        "iomCoverageScore",
        "iomCellCount",
        "iomCoveredCount",
        "mon",
        "pnhImmunity",
        "wasmStatus",
        "wasmBinaryHash",
        "syncedAtUtc",
        "learningOutcomes",
        "ajiStatus",
        "identityStatus",
        "room17"
      ],
      "properties": {
        "learningOutcomes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "candidateSuccessRate",
            "meanBestScoreWithLessons",
            "orderChangeRate",
            "tasteClusterHitRate",
            "authoritative",
            "sampleCount",
            "confidence",
            "note"
          ],
          "properties": {
            "candidateSuccessRate": { "type": "number" },
            "meanBestScoreWithLessons": { "type": "number" },
            "orderChangeRate": { "type": "number" },
            "tasteClusterHitRate": { "type": "number" },
            "authoritative": { "const": false },
            "note": { "type": "string", "minLength": 1 },
            "sampleCount": { "type": "number", "minimum": 0 },
            "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        },
        "testsPassed": {
          "type": "number"
        },
        "testsTotal": {
          "type": "number"
        },
        "iomCoverageScore": {
          "type": "number"
        },
        "iomCellCount": {
          "type": "number"
        },
        "iomCoveredCount": {
          "type": "number"
        },
        "mon": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "ready",
            "source"
          ],
          "properties": {
            "value": {
              "type": "number"
            },
            "ready": {
              "type": "boolean"
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "pnhImmunity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "total",
            "breaches",
            "status",
            "scenarioManifestHash"
          ],
          "properties": {
            "passed": {
              "type": "number"
            },
            "total": {
              "type": "number"
            },
            "breaches": {
              "type": "number"
            },
            "status": {
              "type": "string",
              "enum": [
                "clean",
                "breach"
              ]
            },
            "scenarioManifestHash": {
              "type": "string"
            }
          }
        },
        "wasmStatus": {
          "type": "string",
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "wasmBinaryHash": {
          "type": ["string", "null"]
        },
        "syncedAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "ajiStatus": {
          "type": "object",
          "additionalProperties": false,
          "required": ["activationRate", "lastActivatedAtUtc", "activeSessions", "source"],
          "properties": {
            "activationRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "lastActivatedAtUtc": { "type": ["string", "null"] },
            "activeSessions": { "type": "number", "minimum": 0 },
            "source": { "type": "string", "const": "derived" }
          }
        },
        "identityStatus": {
          "type": "object",
          "additionalProperties": false,
          "required": ["integrity", "ajiActive", "lastActivationAtUtc", "consistency", "source"],
          "properties": {
            "integrity": { "type": "string", "enum": ["ok", "degraded"] },
            "ajiActive": { "type": "boolean" },
            "lastActivationAtUtc": { "type": ["string", "null"] },
            "consistency": { "type": "string", "enum": ["consistent", "mismatch"] },
            "source": { "type": "string", "const": "derived" }
          }
        },
        "humanitarianIntegrity": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["activeScenarios", "scenariosAtSAFE7OrAbove", "anyHardStop", "lastCheckedAt"],
          "properties": {
            "activeScenarios": { "type": "number" },
            "scenariosAtSAFE7OrAbove": { "type": "number" },
            "anyHardStop": { "type": "boolean" },
            "lastCheckedAt": { "type": "string", "format": "date-time" }
          }
        },
        "room17": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "graduationRate",
            "sessionsTotal",
            "ideasGraduated",
            "ideasReturned",
            "emergenceTypes"
          ],
          "properties": {
            "graduationRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "sessionsTotal": { "type": "integer", "minimum": 0 },
            "ideasGraduated": { "type": "integer", "minimum": 0 },
            "ideasReturned": { "type": "integer", "minimum": 0 },
            "lastSessionAt": { "type": ["string", "null"], "format": "date-time" },
            "emergenceTypes": {
              "type": "object",
              "additionalProperties": false,
              "required": ["direct", "triangulated", "unexpected", "none"],
              "properties": {
                "direct": { "type": "integer", "minimum": 0 },
                "triangulated": { "type": "integer", "minimum": 0 },
                "unexpected": { "type": "integer", "minimum": 0 },
                "none": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "divergences": {
      "type": "array"
    },
    "trustless": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifiable",
        "status"
      ],
      "properties": {
        "verifiable": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "unverified",
            "mismatch"
          ]
        },
        "chainRootHash": { "type": "string" },
        "merkleRootHash": { "type": "string" },
        "signingKeyId": { "type": "string" },
        "externalTimestamp": { "type": "number" },
        "input_bytes_hex": { "type": "string" }
      }
    }
  }
}
