{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemist.local/schemas/truth-matrix.schema.json",
  "title": "AIOM Truth Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "divergenceCheckedAtUtc",
    "verification",
    "sources",
    "learningOutcomes",
    "metrics",
    "divergences"
  ],
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 3
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "divergenceCheckedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "verification": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifyPostSummary",
        "metrics",
        "learningFitnessReport"
      ],
      "properties": {
        "verifyPostSummary": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "string",
          "minLength": 1
        },
        "learningFitnessReport": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "learningOutcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateSuccessRate",
        "meanBestScoreWithLessons",
        "orderChangeRate",
        "tasteClusterHitRate",
        "authoritative",
        "note"
      ],
      "properties": {
        "candidateSuccessRate": { "type": "number" },
        "meanBestScoreWithLessons": { "type": "number" },
        "orderChangeRate": { "type": "number" },
        "tasteClusterHitRate": { "type": "number" },
        "authoritative": { "const": false },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testsPassed",
        "testsTotal",
        "iomCoverageScore",
        "mon",
        "pnhImmunity",
        "wasmStatus",
        "syncedAtUtc"
      ],
      "properties": {
        "testsPassed": {
          "type": "number"
        },
        "testsTotal": {
          "type": "number"
        },
        "iomCoverageScore": {
          "type": "number"
        },
        "mon": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "ready",
            "source"
          ],
          "properties": {
            "value": {
              "type": "number"
            },
            "ready": {
              "type": "boolean"
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "pnhImmunity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "total",
            "breaches",
            "status"
          ],
          "properties": {
            "passed": {
              "type": "number"
            },
            "total": {
              "type": "number"
            },
            "breaches": {
              "type": "number"
            },
            "status": {
              "type": "string",
              "enum": [
                "clean",
                "breach"
              ]
            }
          }
        },
        "wasmStatus": {
          "type": "string",
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "syncedAtUtc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "divergences": {
      "type": "array"
    }
  }
}
