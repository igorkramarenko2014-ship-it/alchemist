{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemist.local/schemas/truth-matrix.schema.json",
  "title": "AIOM Truth Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "divergenceCheckedAtUtc",
    "verification",
    "sources",
    "metrics",
    "divergences"
  ],
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 2
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "divergenceCheckedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "verification": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifyPostSummary",
        "metrics"
      ],
      "properties": {
        "verifyPostSummary": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testsPassed",
        "testsTotal",
        "iomCoverageScore",
        "mon",
        "pnhImmunityCount",
        "pnhTotalScenarios",
        "pnhBreaches",
        "wasmStatus",
        "syncedDateUtc"
      ],
      "properties": {
        "testsPassed": {
          "type": "number"
        },
        "testsTotal": {
          "type": "number"
        },
        "iomCoverageScore": {
          "type": "number"
        },
        "mon": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "ready",
            "source"
          ],
          "properties": {
            "value": {
              "type": "number"
            },
            "ready": {
              "type": "boolean"
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "pnhImmunityCount": {
          "type": "number"
        },
        "pnhTotalScenarios": {
          "type": "number"
        },
        "pnhBreaches": {
          "type": "number"
        },
        "wasmStatus": {
          "type": "string",
          "enum": [
            "available",
            "unavailable"
          ]
        },
        "syncedDateUtc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "divergences": {
      "type": "array"
    }
  }
}
