{
  "version": "1.0",
  "endpoints": [
    "GET /health",
    "POST /api/v1/submit",
    "GET /api/health",
    "GET /api/health/wasm",
    "POST /api/triad/llama",
    "POST /api/triad/deepseek",
    "POST /api/triad/qwen"
  ],
  "wasmAccess": [
    "readOnlyMemory"
  ],
  "allowedFailureModes": [
    "ValidationError",
    "RateLimitExceeded",
    "AuthenticationFailed",
    "triad_unconfigured",
    "wasm_unavailable"
  ],
  "verifyIntegrity": "strict",
  "allowedExpansions": []
}
